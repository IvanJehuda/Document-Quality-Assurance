LLM_PROVIDER=groq

# Vision provider for PDF image extraction (used when PDF has no text layer).
# "google" → Gemini (default), "groq" → llama-4-scout via Groq API.
VISION_PROVIDER=groq

# Ollama (runs locally, no API key needed - good default for free local testing)
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# Groq (used when LLM_PROVIDER=groq or VISION_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VISION_MAX_TOKENS=8192

# Google AI Studio / Gemini (used when LLM_PROVIDER=google or VISION_PROVIDER=google)
GOOGLE_API_KEY=your_google_ai_studio_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MAX_OUTPUT_TOKENS=0  # 0 = use model default (recommended)

DATABASE_PATH=statistik_makro.db
