LLM_PROVIDER=groq

# Vision provider for PDF image extraction (used when PDF has no text layer).
# "google" → Gemini (default), "groq" → llama-4-scout via Groq API.
VISION_PROVIDER=groq

# Pages sent per vision LLM call. Fewer, larger calls beat many small ones under a
# requests-per-minute cap (Gemini free tier ≈ 5 rpm). 0 = per-provider auto: Gemini
# batches 3/call, Groq (token-throttled) and local providers stay 1/call. Set e.g. 3
# to force batching on any provider.
VISION_PAGES_PER_CALL=0

# Ollama (runs locally, no API key needed - good default for free local testing)
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# Groq (used when LLM_PROVIDER=groq or VISION_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VISION_MAX_TOKENS=8192

# Google AI Studio / Gemini (used when LLM_PROVIDER=google or VISION_PROVIDER=google)
GOOGLE_API_KEY=your_google_ai_studio_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MAX_OUTPUT_TOKENS=0  # 0 = use model default (recommended)

DATABASE_PATH=statistik_makro.db

# Access control - HTTP Basic Auth for the WHOLE app.
# Set BOTH to require a login before anyone can use the app; leave either blank
# to disable auth (e.g. local dev). On the host, set these as Secrets, not here.
APP_USERNAME=
APP_PASSWORD=
